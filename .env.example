# ============================================================
# APP
# ============================================================
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CORS_ORIGIN=*

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/digitag?schema=public"

# ============================================================
# JWT
# ============================================================
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ============================================================
# OTP
# ============================================================
# Provider: mock | twilio | msg91 | firebase
OTP_PROVIDER=mock
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# MSG91 (optional)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=

# ============================================================
# AWS S3
# ============================================================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=digitag-uploads
AWS_S3_PUBLIC_URL=
AWS_S3_SIGNED_URL_EXPIRES_IN=900

# ============================================================
# RATE LIMIT
# ============================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
OTP_RATE_LIMIT_MAX=5

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info
